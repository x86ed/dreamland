{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {"type": "command", "command": "dreamland version-bump"},
          {"type": "command", "command": "dreamland coauthor"}
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {"type": "command", "command": "dreamland version-bump --patch"},
          {"type": "command", "command": "dreamland transition-log"},
          {"type": "command", "command": "dreamland test"}
        ]
      }
    ]
  }
}
