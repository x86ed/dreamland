{
  "name": "dreamland",
  "hooks": {
    "agentSpawn": [
      {"command": "dreamland version-bump"},
      {"command": "dreamland coauthor"}
    ],
    "stop": [
      {"command": "dreamland version-bump --patch"},
      {"command": "dreamland transition-log"},
      {"command": "dreamland test"},
      {"command": "dreamland telemetry write --tool kiro"}
    ]
  }
}
